{
  "name": "tt-ide-cli",
  "version": "0.1.33",
  "description": "Command line interface for micro app development",
  "license": "ISC",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tma": "bin/tma.js"
  },
  "files": [
    "bin",
    "templates",
    "dist",
    "skill"
  ],
  "scripts": {
    "build": "cross-env NODE_ENV=production NODE_OPTIONS=--max-old-space-size=4096 webpack --progress",
    "build:cli": "cross-env NODE_ENV=production BUILD_ENV=CLI NODE_OPTIONS=--max-old-space-size=4096 webpack --config webpack.cli.js --progress",
    "dev": "cross-env NODE_ENV=development webpack --watch",
    "prepublishOnly": "yarn build:cli",
    "test": "npx patch-package && jest"
  },
  "resolutions": {
    "commander": "5.1.0"
  },
  "dependencies": {
    "@tt-miniprogram/ext-pack": "1.2.4",
    "archiver": "^5.3.0",
    "chalk": "^4.1.2",
    "clipboardy": "^2.2.0",
    "commander": "5.1.0",
    "deep-clone": "^3.0.3",
    "easy-table": "^1.2.0",
    "fast-glob": "3.3.2",
    "folder-hash": "^4.0.1",
    "form-data": "^4.0.0",
    "fs-extra": "^10.0.0",
    "inquirer": "^8.2.0",
    "node-machine-id": "^1.1.12",
    "ora": "^5.4.1",
    "qrcode": "^1.4.4",
    "qrcode-terminal": "^0.12.0",
    "semver-compare": "^1.0.0",
    "unzipper": "^0.10.11"
  },
  "devDependencies": {
    "@byted/miniprogram-utils": "^1.0.0",
    "@types/archiver": "^5.1.1",
    "@types/chalk": "^2.2.0",
    "@types/folder-hash": "^4.0.1",
    "@types/fs-extra": "^9.0.13",
    "@types/inquirer": "^8.1.3",
    "@types/jest": "^27.0.2",
    "@types/node": "16.18.108",
    "@types/qrcode": "^1.4.2",
    "@types/qrcode-terminal": "^0.12.0",
    "@types/unzipper": "^0.10.4",
    "@types/webpack-merge": "4.1.5",
    "clean-webpack-plugin": "4.0.0",
    "cross-env": "^7.0.3",
    "jest": "^26.6.3",
    "patch-package": "^6.4.7",
    "ts-jest": "^26.5.6",
    "ts-loader": "8.0.5",
    "webpack-merge": "4.2.2"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  }
}
