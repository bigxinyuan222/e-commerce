# ==========================
# 1. 依赖与构建产物 (核心)
# ==========================
node_modules/          # npm/yarn/pnpm 安装的依赖包 (绝对不要提交)
lxg-frontend/dist/     # Taro 编译生成的小程序代码 (每次构建都会变)
dist/                  # 防止其他模块也输出 dist 目录
*.log                  # 日志文件

# ==========================
# 2. 操作系统临时文件
# ==========================
.DS_Store              # Mac 系统文件夹属性文件
Thumbs.db              # Windows 缩略图缓存
desktop.ini            # Windows 文件夹配置文件

# ==========================
# 3. 编辑器与 IDE 配置
# ==========================
.vscode/               # VS Code 工作区配置 (可选，团队统一可提交)
.idea/                 # JetBrains 系列 IDE (WebStorm/IntelliJ)
*.swp                  # Vim 交换文件
*.swo                  # Vim 交换文件

# ==========================
# 4. 环境变量与安全 (重要!)
# ==========================
.env                   # 本地环境变量 (可能包含密钥)
.env.local             # 本地覆盖配置
.env.*.local           # 所有本地环境文件